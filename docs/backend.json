
{
  "entities": {
    "User": {
      "title": "Empleado/Usuario",
      "description": "Perfil del empleado vinculado a credenciales de usuario y gamificación.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "Emp_Nombre": { "type": "string" },
        "Emp_Correo": { "type": "string", "format": "email" },
        "Rol_ID": { "type": "number", "description": "1: Admin, 2: Empleado" },
        "puntos": { "type": "number" },
        "nivel": { "type": "number" },
        "racha": { "type": "number" },
        "projectStatus": { "type": "object" }
      },
      "required": ["uid", "Emp_Nombre", "Rol_ID"]
    },
    "Project": {
      "title": "Proyecto (PRY)",
      "description": "Contenedor principal de la actividad operativa.",
      "type": "object",
      "properties": {
        "Pry_Nombre_Proyecto": { "type": "string" },
        "Cl_ID": { "type": "string", "description": "ID del cliente vinculado" },
        "Srv_ID": { "type": "string", "description": "ID del servicio vinculado" },
        "Eq_ID": { "type": "string", "description": "ID del equipo asignado" },
        "Pry_Estado": { "type": "string", "enum": ["Pendiente", "EnProceso", "Finalizado"] },
        "ubicacion": { "type": "string" },
        "imageUrl": { "type": "string" },
        "progreso": { "type": "number" },
        "fecha_creacion": { "type": "string", "format": "date-time" }
      },
      "required": ["Pry_Nombre_Proyecto", "Cl_ID", "Srv_ID", "Eq_ID", "Pry_Estado"]
    },
    "Client": {
      "title": "Cliente (CL)",
      "description": "Registro de clientes y razón social.",
      "type": "object",
      "properties": {
        "Cl_Nombre": { "type": "string" },
        "Cl_RazonSocial": { "type": "string" },
        "Cl_Correo": { "type": "string", "format": "email" },
        "Cl_Telefono": { "type": "string" }
      }
    },
    "Material": {
      "title": "Material (MAT)",
      "description": "Catálogo de inventario.",
      "type": "object",
      "properties": {
        "Mat_Nombre": { "type": "string" },
        "Mat_Stock_Disponible": { "type": "number" }
      }
    },
    "Report": {
      "title": "Reporte (REP)",
      "description": "Documentación final de actividades.",
      "type": "object",
      "properties": {
        "Pry_ID": { "type": "string" },
        "Eq_ID": { "type": "string" },
        "Rep_Comentarios": { "type": "string" },
        "Rep_Evidencia_URL": { "type": "string" },
        "fecha": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Perfiles de empleados y gamificación."
    },
    "/proyectos/{projectId}": {
      "schema": "Project",
      "description": "Proyectos operativos."
    },
    "/clientes/{clientId}": {
      "schema": "Client",
      "description": "Catálogo de clientes."
    },
    "/materiales/{materialId}": {
      "schema": "Material",
      "description": "Inventario de materiales."
    },
    "/reportes/{reportId}": {
      "schema": "Report",
      "description": "Historial de reportes operativos."
    }
  }
}
