
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    
    // Función robusta para verificar rol de administrador
    function isAdmin() { 
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.rol == 'admin'; 
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    match /notifications/{notifId} {
      // Permitir lectura si el documento pertenece al usuario o si es admin
      // La regla 'read' cubre tanto 'get' como 'list'
      allow read: if isSignedIn() && (
        isAdmin() || 
        (resource != null && resource.data.userId == request.auth.uid)
      );
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /projects/{projectId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /proyectos/{projectId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /teams/{teamId} {
      // Los empleados pueden leer equipos si son miembros
      allow read: if isSignedIn() && (
        isAdmin() || 
        (resource != null && request.auth.uid in resource.data.members)
      );
      allow write: if isAdmin();
    }

    match /reports/{reportId} {
      // Los empleados ven sus propios reportes, el admin ve todos
      allow read: if isSignedIn() && (
        isAdmin() || 
        (resource != null && resource.data.employeeId == request.auth.uid)
      );
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        isAdmin() || 
        (resource != null && resource.data.employeeId == request.auth.uid)
      );
      allow delete: if isAdmin();
    }
    
    match /materiales/{matId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /checklist_servicio/{checkId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /clientes/{clientId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
