rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && (getUserData().role == 'admin' || getUserData().rol == 'admin');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /userProfiles/{userProfileId} {
      allow get, list: if isOwner(userProfileId) || isAdmin();
      allow create: if isOwner(userProfileId);
      allow update: if isOwner(userProfileId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow get, list, write: if isSignedIn();
    }

    match /proyectos/{projectId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /materiales/{materialId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /checklist_servicio/{serviceId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /clientes/{clienteId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /teams/{teamId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /reports/{reportId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }
  }
}