rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * ZYRA SECURITY RULES PHILOSOPHY
     * 
     * This ruleset implements a strict, role-based and ownership-based security model designed for
     * solar energy project management. It prioritizes "Authorization Independence" by leveraging 
     * denormalized fields (like teamId and employeeId) directly on documents to ensure fast, 
     * non-recursive security checks.
     * 
     * DATA STRUCTURE & ACCESS:
     * - /users: User profiles, including 'role' (admin/employee) and 'teamId'.
     * - /projects: Solar projects, accessible by admins or employees assigned to the project's team.
     * - /teams: Operational team data, accessible by team members, leaders, or admins.
     * - /reports: Daily operational reports, owned by employees and shared with their project teams.
     * - /achievements: Read-only catalog for gamification, managed by admins.
     * 
     * KEY DECISIONS:
     * - Denormalization: Fields like 'assignedTeamId' are expected on Project and Report documents 
     *   to allow membership-based access without cross-collection lookups.
     * - Roles: Admin users have overarching access to manage data across the system.
     * - Prototyping Mode: Schema validation (types/optionality) is omitted to allow rapid data 
     *   iteration, but relational integrity for ownership and roles is strictly enforced.
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && getUserData().role == 'admin';
    }

    function isExistingOwner(ownerId) {
      return resource != null && (resource.data[ownerId] == request.auth.uid);
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for the User collection. Allows users to manage their own profile and admins to see all.
     * @path /users/{userId}
     * @allow (get, list) if the user is the owner or an admin.
     * @deny (create) if the userId path variable does not match the auth UID.
     * @principle Ownership-based access for profiles with administrative overrides.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if (isOwner(userId) || isAdmin()) && resource != null;
      allow delete: if isAdmin() && resource != null;
    }

    /**
     * @description Rules for Solar Energy Projects. Access is granted based on assigned team membership.
     * @path /projects/{projectId}
     * @allow (get, list) if the user is an admin or belongs to the project's assignedTeamId.
     * @deny (write) if the user is not an administrator.
     * @principle Shared access based on denormalized team identifiers.
     */
    match /projects/{projectId} {
      allow get, list: if isAdmin() || (isSignedIn() && getUserData().teamId == resource.data.assignedTeamId);
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Rules for Operational Teams. Only members and leaders of the team can view the details.
     * @path /teams/{teamId}
     * @allow (get, list) if the user is an admin, the leader, or a member of the team.
     * @deny (update) if the user is not an admin or the designated team leader.
     * @principle Closed collaborator model using array and map lookups.
     */
    match /teams/{teamId} {
      allow get, list: if isAdmin() || (isSignedIn() && (request.auth.uid in resource.data.memberIds || resource.data.leaderId == request.auth.uid));
      allow create: if isAdmin();
      allow update: if (isAdmin() || (resource != null && resource.data.leaderId == request.auth.uid));
      allow delete: if isAdmin() && resource != null;
    }

    /**
     * @description Rules for Daily Operational Reports. Reports are owned by employees and shared with their teams.
     * @path /reports/{reportId}
     * @allow (get, list) if the user is the author, an admin, or in the same project team.
     * @allow (create) if the authenticated user sets themselves as the employeeId.
     * @principle Ownership for creation and shared team access for visibility.
     */
    match /reports/{reportId} {
      allow get, list: if isAdmin() || isExistingOwner('employeeId') || (isSignedIn() && getUserData().teamId == resource.data.assignedTeamId);
      allow create: if isSignedIn() && request.resource.data.employeeId == request.auth.uid;
      allow update: if (isAdmin() || isExistingOwner('employeeId')) && resource != null;
      allow delete: if (isAdmin() || isExistingOwner('employeeId')) && resource != null;
    }

    /**
     * @description Rules for the Achievement catalog. Publicly readable by all users but strictly managed by admins.
     * @path /achievements/{achievementId}
     * @allow (get, list) if the user is signed in.
     * @deny (write) for any non-admin user.
     * @principle Public consumption with administrative control.
     */
    match /achievements/{achievementId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }
  }
}